{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "entry": ["src/main.tsx"],
  "project": ["src/**/*.{ts,tsx}"],
  "ignore": [
    "src/protogen/**",
    "src/components/ui/**",
    "src/hooks/use-mobile.ts",
    "src/components/data-grid/data-table-filter.tsx"
  ],
  "vitest": {
    "entry": ["**/*.test.ts", "**/*.test.tsx", "**/*.spec.ts", "**/*.spec.tsx"]
  }
}
