{
  "name": "frontend-new",
  "private": true,
  "version": "0.1.0",
  "packageManager": "bun@1.3.14",
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev": "rsbuild dev",
    "type:check": "bun run type:check:ui && tsgo -b --pretty false",
    "build": "rsbuild build && bun run budget:check",
    "preview": "rsbuild preview",
    "doctor": "react-doctor . -y --scope full --no-respect-inline-disables",
    "quality:gate": "bun run lint && bun run doctor && bun run type:check && bun run build && bun run test:unit && bun run test:integration",
    "test:unit": "vitest run --config vitest.unit.config.ts",
    "test:unit:watch": "vitest watch --config vitest.unit.config.ts",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:integration:watch": "vitest watch --config vitest.integration.config.ts",
    "test:vitest": "NODE_OPTIONS=--disable-warning=DEP0205 TZ=GMT vitest run --config vitest.config.ts",
    "test:vitest:watch": "NODE_OPTIONS=--disable-warning=DEP0205 TZ=GMT vitest watch --config vitest.config.ts",
    "test:browser": "NODE_OPTIONS=--disable-warning=DEP0205 TZ=GMT vitest run --config vitest.browser.config.ts",
    "test:e2e": "env -u NO_COLOR NODE_OPTIONS=--disable-warning=DEP0205 playwright test --config=e2e/playwright.config.ts --grep-invert @a11y",
    "test:e2e:ui": "env -u NO_COLOR NODE_OPTIONS=--disable-warning=DEP0205 playwright test --config=e2e/playwright.config.ts --ui",
    "test:accessibility": "env -u NO_COLOR NODE_OPTIONS=--disable-warning=DEP0205 playwright test --config=e2e/playwright.config.ts --grep @a11y",
    "test:browser:setup": "env -u NO_COLOR NODE_OPTIONS=--disable-warning=DEP0205 playwright install --with-deps chromium",
    "lint": "ultracite check && bun run suppressions:check",
    "lint:fix": "ultracite fix && bun run suppressions:check",
    "format": "bun run lint:fix",
    "changeset": "changeset",
    "changeset:version": "changeset version",
    "changeset:tag": "changeset tag",
    "check": "bun run lint",
    "fix": "bun run lint:fix",
    "budget:check": "bun run scripts/check-bundle-budget.ts",
    "perf:check": "bun run scripts/perf-budgets.ts",
    "lighthouse:ci": "bun run scripts/run-lighthouse-ci.ts",
    "lighthouse:summary": "bun run scripts/lighthouse-summary.ts ./dist/lighthouse",
    "lighthouse:public": "LIGHTHOUSE_RUNS=1 LIGHTHOUSE_UPLOAD_TARGET=temporary-public-storage bun run scripts/run-lighthouse-ci.ts",
    "perf:lighthouse": "bun run build && bun run lighthouse:ci && bun run lighthouse:summary",
    "perf:lighthouse:public": "bun run build && bun run lighthouse:public",
    "build:profile": "rm -rf dist && RSDOCTOR=1 rsbuild build",
    "type:check:ui": "tsgo -p tsconfig.ui.json --pretty false",
    "postinstall": "if [ \"$NODE_ENV\" = \"production\" ] || [ \"$npm_config_production\" = \"true\" ] || ! command -v tsgo >/dev/null 2>&1; then exit 0; fi; bun run type:check:ui",
    "test:e2e:debug": "env -u NO_COLOR NODE_OPTIONS=--disable-warning=DEP0205 playwright test --config=e2e/playwright.config.ts --debug",
    "test:e2e:debug:cli": "env -u NO_COLOR NODE_OPTIONS=--disable-warning=DEP0205 playwright test --config=e2e/playwright.config.ts --debug=cli",
    "test:e2e:list": "env -u NO_COLOR NODE_OPTIONS=--disable-warning=DEP0205 playwright test --config=e2e/playwright.config.ts --list --reporter=list",
    "test:e2e:repeat": "env -u NO_COLOR NODE_OPTIONS=--disable-warning=DEP0205 playwright test --config=e2e/playwright.config.ts --grep-invert @a11y --repeat-each=2",
    "test": "bun run test:unit && bun run test:integration",
    "test:integration:leaks": "vitest run --config vitest.integration.config.ts --detectAsyncLeaks",
    "test:unit:ci": "vitest run --config vitest.unit.config.ts --reporter=verbose",
    "test:integration:ci": "vitest run --config vitest.integration.config.ts --reporter=verbose",
    "test:browser:update": "NODE_OPTIONS=--disable-warning=DEP0205 TZ=GMT vitest run --config vitest.browser.config.ts --update",
    "test:browser:ui": "NODE_OPTIONS=--disable-warning=DEP0205 TZ=GMT vitest --config vitest.browser.config.ts --ui",
    "test:browser:ci": "NODE_OPTIONS=--disable-warning=DEP0205 TZ=GMT vitest run --config vitest.browser.all.config.ts --reporter=verbose",
    "doctor:ci": "bun run doctor:changed",
    "doctor:changed": "react-doctor . -y --scope changed --base ${QUALITY_BASE_REF:-origin/main} --no-respect-inline-disables",
    "doctor:full": "react-doctor . -y --scope full --no-respect-inline-disables",
    "doctor:audit": "bun run doctor",
    "lint:changed": "bun run scripts/lint-changed.ts && bun run suppressions:check",
    "test:unit:changed": "vitest run --config vitest.unit.config.ts --changed ${QUALITY_BASE_REF:-origin/main} --passWithNoTests",
    "test:integration:changed": "vitest run --config vitest.integration.config.ts --changed ${QUALITY_BASE_REF:-origin/main} --passWithNoTests",
    "test:browser:changed": "NODE_OPTIONS=--disable-warning=DEP0205 TZ=GMT vitest run --config vitest.browser.all.config.ts --changed ${QUALITY_BASE_REF:-origin/main} --passWithNoTests",
    "quality:changed": "bun run lint:changed && bun run doctor:changed && bun run type:check && bun run test:unit:changed && bun run test:integration:changed && bun run test:browser:changed",
    "suppressions:check": "bun run scripts/check-suppressions.ts"
  },
  "dependencies": {
    "@base-ui/react": "1.6.0",
    "@bufbuild/protobuf": "2.12.1",
    "@bufbuild/protovalidate": "1.2.0",
    "@connectrpc/connect": "2.1.2",
    "@connectrpc/connect-query": "2.2.0",
    "@connectrpc/connect-query-core": "2.2.0",
    "@connectrpc/connect-web": "2.1.2",
    "@fontsource-variable/geist": "5.2.9",
    "@fontsource-variable/geist-mono": "5.2.8",
    "@sentry/react": "10.63.0",
    "@shikijs/langs": "4.3.1",
    "@shikijs/themes": "4.3.1",
    "@t3-oss/env-core": "0.13.11",
    "@tanstack/query-core": "5.101.2",
    "@tanstack/react-query": "5.101.2",
    "@tanstack/react-query-devtools": "5.101.2",
    "@tanstack/react-router": "1.170.17",
    "@tanstack/react-router-devtools": "1.167.0",
    "@tanstack/react-table": "9.0.0-beta.30",
    "@tanstack/router-plugin": "1.168.19",
    "@tanstack/virtual-core": "3.17.3",
    "@xyflow/react": "12.11.1",
    "chrono-node": "2.9.1",
    "class-variance-authority": "0.7.1",
    "cmdk": "1.1.1",
    "cnfast": "0.0.8",
    "date-fns": "4.4.0",
    "lucide-react": "1.23.0",
    "next-themes": "0.4.6",
    "posthog-js": "1.396.6",
    "react": "19.2.7",
    "react-data-grid": "7.0.0-beta.59",
    "react-day-picker": "10.0.1",
    "react-dom": "19.2.7",
    "react-hook-form": "7.80.0",
    "react-resizable-panels": "4.12.1",
    "recharts": "^3.9.2",
    "shiki": "4.3.1",
    "sonner": "2.0.7",
    "tailwindcss": "4.3.2",
    "zod": "4.4.3",
    "zustand": "5.0.14"
  },
  "devDependencies": {
    "@axe-core/playwright": "4.12.2-2d3cb18.0",
    "@biomejs/biome": "2.5.2",
    "@changesets/cli": "^2.31.0",
    "@lhci/cli": "0.15.1",
    "@rsbuild/core": "2.1.4",
    "@rsbuild/plugin-react": "2.1.0",
    "@rsbuild/plugin-tailwindcss": "2.0.3",
    "@rsdoctor/rspack-plugin": "1.5.17",
    "@rspack/core": "2.1.2",
    "@sentry/webpack-plugin": "5.3.0",
    "@tailwindcss/postcss": "4.3.2",
    "@tailwindcss/vite": "4.3.2",
    "@testing-library/dom": "10.4.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/node": "26.1.0",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@typescript/native-preview": "7.0.0-dev.20260705.1",
    "@vitest/browser": "5.0.0-beta.5",
    "@vitest/browser-playwright": "5.0.0-beta.5",
    "@vitest/ui": "5.0.0-beta.5",
    "dotenv": "17.4.2",
    "happy-dom": "20.10.6",
    "playwright": "1.61.1",
    "playwright-core": "1.61.1",
    "react-doctor": "0.6.2",
    "rsbuild-plugin-devtools-json": "1.0.1",
    "shadcn": "4.13.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "6.0.3",
    "ultracite": "7.8.4",
    "vitest": "5.0.0-beta.5",
    "vitest-browser-react": "2.2.0"
  }
}
