---
import { type rpcPresentation } from "./rpc-kind.ts";

interface Props {
  presentation: ReturnType<typeof rpcPresentation>;
  class?: string;
}

const { presentation, class: className } = Astro.props;
---

<span
  class:list={[
    "not-prose inline-flex shrink-0 items-center whitespace-nowrap rounded-md px-2 py-0.5 font-mono font-semibold text-xs uppercase tracking-wide",
    presentation.className,
    className,
  ]}
>{presentation.label}</span>
